# FloraFlow Configuration Settings

# MQTT Broker Settings
# MQTT_HOST: Address of the MQTT Broker (e.g. Home Assistant IP). Default: "homeassistant.local"
MQTT_HOST=homeassistant.local

# MQTT_PORT: Port of the MQTT Broker. Default: 1883
MQTT_PORT=1883

# MQTT credentials (leave blank if not enabled/required)
MQTT_USERNAME=
MQTT_PASSWORD=

# Client settings
# MQTT_CLIENT_ID: Identifier for this client on the MQTT broker. Default: "rpi_relay_controller"
MQTT_CLIENT_ID=rpi_relay_controller

# Home Assistant discovery configuration
# MQTT_DISCOVERY_PREFIX: Discovery prefix for Home Assistant MQTT Auto-Discovery. Default: "homeassistant"
MQTT_DISCOVERY_PREFIX=homeassistant

# Scheduler & Persistence
# PERSISTENCE_FILE: File path to save schedules. Default: "schedules.json"
PERSISTENCE_FILE=schedules.json

# DHT22 Configuration
# DHT_PIN: Physical pin of the DHT sensor (BCM mapping). Default: 4
DHT_PIN=4

# DHT_INTERVAL: Frequency of reading sensor and publishing to HA in seconds. Default: 60
DHT_INTERVAL=60
